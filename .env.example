# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ppai:ppaipass@localhost:5432/placementprep
POSTGRES_USER=ppai
POSTGRES_PASSWORD=ppaipass
POSTGRES_DB=placementprep

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_64_char_random_hex_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth + Calendar ───────────────────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Calendar API, Google OAuth2 API
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# ── LLM ───────────────────────────────────────────────────────────────────────
# Options: "gemini" | "openai" | "none"
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Judge0 ────────────────────────────────────────────────────────────────────
JUDGE0_API_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ── Files ─────────────────────────────────────────────────────────────────────
RESUME_UPLOAD_DIR=./uploads/resumes
MAX_RESUME_SIZE_MB=5

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8000
